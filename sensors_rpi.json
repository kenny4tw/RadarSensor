{
  "log_dir": "./logs",
  "enable_logging": true,
  "json_api_port": 8080,
  "enable_json_api": true,
  "sensors": [
    {
      "id": "sensor1",
      "name": "Primary Radar Sensor",
      "connection_type": "serial",
      "serial_port": "/dev/ttyUSB0",
      "mode": "velocity",
      "output_rate": 10.0,
      "log_max_size": 10485760,
      "velocity_config": {
        "surface_distance": 2.3,
        "angle": 45.0,
        "num_points": 4,
        "sweeps": 128,
        "hwaas": 16,
        "time_series": 512,
        "lp_coeff": 0.75,
        "cfar_sensitivity": 0.5,
        "max_peak_interval": 1.0,
        "slow_zone": 3
      },
      "distance_config": {
        "start": 1.5,
        "end": 3.0,
        "update_rate": 10.0,
        "signal_quality": 25.0,
        "threshold_sensitivity": 0.35,
        "min_strength": 5.0,
        "avg_window": 5
      }
    }
  ]
}
